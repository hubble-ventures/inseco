{
  "$schema": "https://hubble-ventures.github.io/inseco/secrets.schema.json",
  "paths": ["clerk", "posthog", "stripe"],
  "aliases": {
    "CLERK_PUBLISHABLE_KEY": "VITE_CLERK_PUBLISHABLE_KEY",
    "POSTHOG_PROJECT_TOKEN": "VITE_POSTHOG_KEY"
  },
  "profiles": {
    "deploy": { "paths": ["clerk", "posthog", "stripe", "fly"] }
  },
  "ci": {
    "skipWhenEnv": ["VITE_CLERK_PUBLISHABLE_KEY"]
  },
  "environments": {
    "preview": {
      "optionalKeys": ["POSTHOG_PROJECT_TOKEN", "STRIPE_WEBHOOK_SECRET"]
    }
  }
}
