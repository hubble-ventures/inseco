{
  "$schema": "https://cdn.jsdelivr.net/npm/@hubble-ventures/infisicml@2/schema/secrets.schema.json",
  "tree": {
    "clerk": [{ "CLERK_PUBLISHABLE_KEY": "VITE_CLERK_PUBLISHABLE_KEY" }],
    "posthog": [{ "POSTHOG_PROJECT_TOKEN": "VITE_POSTHOG_KEY" }],
    "stripe": ["STRIPE_PUBLISHABLE_KEY", "STRIPE_WEBHOOK_SECRET"]
  },
  "profiles": {
    "deploy": {
      "tree": {
        "clerk": [{ "CLERK_PUBLISHABLE_KEY": "VITE_CLERK_PUBLISHABLE_KEY" }],
        "posthog": [{ "POSTHOG_PROJECT_TOKEN": "VITE_POSTHOG_KEY" }],
        "stripe": ["STRIPE_PUBLISHABLE_KEY", "STRIPE_WEBHOOK_SECRET"],
        "fly": ["FLY_API_TOKEN"]
      }
    }
  },
  "ci": {
    "skipWhenEnv": ["VITE_CLERK_PUBLISHABLE_KEY"]
  },
  "environments": {
    "preview": {
      "optionalKeys": ["POSTHOG_PROJECT_TOKEN", "STRIPE_WEBHOOK_SECRET"]
    }
  }
}
